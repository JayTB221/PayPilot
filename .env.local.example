# ─────────────────────────────────────────────────────────────────────────────
#  PayPilot — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Keep secret — server-side only

# ── Stripe ────────────────────────────────────────────────────────────────────
# Found at: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Found at: https://dashboard.stripe.com/webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Found at: https://dashboard.stripe.com/products → your $400/mo product → Price ID
STRIPE_PRICE_ID=price_...

# ── Xero OAuth ────────────────────────────────────────────────────────────────
# Found at: https://developer.xero.com/myapps → your app → Configuration
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://yourdomain.com/xero-callback

# ── Resend (email delivery) ───────────────────────────────────────────────────
# Found at: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=invoices@yourdomain.com

# ── Twilio (SMS delivery) ─────────────────────────────────────────────────────
# Found at: https://console.twilio.com → Account Info panel
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+64...

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Found at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
